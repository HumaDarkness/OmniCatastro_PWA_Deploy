{
  "name": "omnicatastro-pwa",
  "private": true,
  "version": "9.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-api": "orval --config orval.config.ts",
    "build": "tsc -b && vite build",
    "build:with-api": "npm run generate-api && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run src/lib/__tests__/resolveConflict.unit.test.ts",
    "test:integration": "vitest run src/lib/__tests__/syncService.integration.test.ts",
    "test:e2e": "playwright test e2e/conflictReliability.e2e.ts",
    "test:e2e:headed": "playwright test e2e/conflictReliability.e2e.ts --headed",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-oauth/google": "^0.13.4",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docxtemplater": "^3.68.4",
    "docxtemplater-image-module-free": "^1.1.1",
    "dotenv": "^17.3.1",
    "file-saver": "^2.0.5",
    "idb": "^8.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "ky": "^2.0.0",
    "lucide-react": "^0.575.0",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "proj4": "^2.20.4",
    "react": "^19.2.0",
    "react-canvas-confetti": "^2.0.7",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2"
